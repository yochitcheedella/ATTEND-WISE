# ==============================================================================
# ATTENDWISE API PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to '.env' and fill in the actual production values.
# DO NOT commit the '.env' file containing real secrets to version control.
# ==============================================================================

# --- System Mode ---
# Choices: development, testing, production
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# --- Security & Cryptography ---
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your-production-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS & Network Configuration ---
# Comma-separated list of allowed origins. Do not use "*" in production.
ALLOWED_ORIGINS=https://attendwise.yourdomain.com,https://api.attendwise.yourdomain.com

# --- Database Pool (PostgreSQL / Supabase) ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# --- Supabase Platform Config ---
