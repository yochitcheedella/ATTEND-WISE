# Production Environment Variables for AttendWise Backend
# Copy this file to .env on deployment systems

# ========== Database Configuration ==========
DATABASE_URL=postgresql://postgres:password@postgres:5432/attendwise
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret

# ========== Redis Configuration ==========
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ========== Security ==========
SECRET_KEY=change-this-in-production-or-use-env-file-in-production-only
SECRET_KEY_BASE64=
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,http://localhost:3000
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ========== AI Services ==========
# Get your API key from: https://aistudio.google.com/app/apikey
# Format: AIzaSy... (39 characters). Required for OCR and AI insights.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ========== Application Settings ==========
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/app/uploads

# ========== Email Configuration ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=attendwise@yourdomain.com
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# ========== Security Headers ==========
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ========== File Upload ==========
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx
UPLOAD_TEMP_DIR=/tmp/uploads

# ========== Rate Limiting ==========
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_IP_RANGE=24

# ========== Session ==========
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ========== Monitoring ==========
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ========== Analytics ==========
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=google-analytics
ANALYTICS_TRACKING_ID=UA-XXXXXXXXX-X

# ========== AI Features ==========
OCR_ENABLED=true
OCR_MODEL=gemini-2.5-flash
OCR_CONFIDENCE_THRESHOLD=0.8

# ========== Content Delivery ==========
CDN_ENABLED=true
CDN_URL=https://cdn.yourdomain.com
CACHE_CONTROL_MAX_AGE=31536000

# ========== Backup ==========
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=attendwise-backups

# ========== Localization ==========
DEFAULT_LANGUAGE=en
TIMEZONE=UTC
DATE_FORMAT=d/m/Y
TIME_FORMAT=H:i

# ========== API Configuration ==========
API_PREFIX=/api
API_VERSION=1.0.0
API_DOCS_ENABLED=true
API_DOCS_PATH=/docs

# ========== Feature Flags ==========
ENABLE_LEAVE_PLANS=true
ENABLE_ANALYTICS=true
ENABLE_REPORTS=true
ENABLE_OCR=true
ENABLE_AI_INSIGHTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_WEBHOOKS=false

# ========== Payment/Subscription (if applicable) ==========
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ========== Firebase Cloud Messaging (Push Notifications) ==========
# Option A — File path (Docker volume / VPS with mounted file):
#   Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-adminsdk-key.json
#
# Option B — Raw JSON string (Render / Railway / Heroku / any PaaS env var):
#   Copy the entire contents of the service-account JSON and paste as one line.
#   Uncomment the line below and set the value.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"KEY_ID","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
#
# Leave both blank to disable push notifications (app works fully without FCM).


# ========== Development Overrides (should be overridden in production) ==========
# Comment out or set specific values for different environments
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=DEBUG
# DATABASE_URL=sqlite:///./attendwise.db
# REDIS_URL=redis://localhost:6379/0